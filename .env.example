
# ── Backend (Node.js / Express) ──────────────────────────────
SUPABASE_URL=sua-url-supabase
SUPABASE_KEY=sua-chave-supabase
JWT_SECRET=sua-chave-secreta-jwt
ADMIN_SECRET=seu-secret-para-criar-admin
GROQ_API_KEY=sua-chave-groq

# ── Frontend (Vite / React) ───────────────────────────────────
# Cole aqui as credenciais do seu projeto Supabase
# Encontre em: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui

# URL base da API (só necessário quando USE_MOCK=false e backend externo)
VITE_API_URL=https://sistema-hospitalar.onrender.com/api